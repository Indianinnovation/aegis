# Copy this file to .env and fill in your values
# Run: python wizard/setup_wizard.py  (auto-fills everything)

ANTHROPIC_API_KEY=sk-ant-your-key-here

# HashiCorp Vault dev token
VAULT_TOKEN=change-me-vault-token

# Redis password
REDIS_PASSWORD=change-me-redis-password

# Memory encryption master key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
MEMORY_MASTER_KEY=change-me-generate-a-64-char-hex-string

# Comma-separated allowed CORS origins (defaults to http://localhost)
ALLOWED_ORIGINS=http://localhost
